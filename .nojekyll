# Install FFmpeg first if not installed
# For Mac: brew install ffmpeg
# For Windows: download from https://ffmpeg.org/download.html

# Then convert your video
ffmpeg -i your-video.mp4 \
  -c:v libx264 \
  -profile:v baseline \
  -level 3.0 \
  -pix_fmt yuv420p \
  -crf 23 \
  -movflags +faststart \
  -c:a aac \
  -b:a 128k \
  -ar 48000 \
  -ac 2 \
  output-video.mp4